{
  "name": "fabgrid",
  "version": "0.1.0",
  "private": true,
  "description": "Fabulous performance-first pure JavaScript data grid.",
  "type": "module",
  "main": "dist/fabui.js",
  "style": "dist/fabui.css",
  "scripts": {
    "build": "node build/build.cjs",
    "build:all": "npm run build && npm run build:lite && npm run build:diagram && npm run build:gantt && npm run build:scheduler && npm run build:htmleditor",
    "build:diagram": "node build/build-diagram.cjs",
    "build:gantt": "node build/build-gantt.cjs",
    "build:lite": "node build/build-lite.cjs",
    "build:scheduler": "node build/build-scheduler.cjs",
    "build:htmleditor": "node build/build-htmleditor.cjs",
    "build:theme": "node build/build-theme.cjs",
    "build:vue": "node build/build-vue.cjs",
    "build:jquery": "node build/build-jquery.cjs",
    "dev:vue": "python3 -m http.server 4174",
    "benchmark:grid": "node scripts/benchmark-grid.mjs",
    "test": "node --test test/*.test.js",
    "test:jquery": "node --test test/jquery-wrapper.test.js",
    "smoke": "npm run build && node build/smoke.cjs && node build/smoke-gantt.cjs",
    "smoke:gantt": "node build/smoke-gantt.cjs",
    "smoke:scheduler": "npm run build:scheduler && node build/smoke-scheduler.cjs",
    "serve": "python3 -m http.server 4173"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "systemjs": "^0.21.6",
    "systemjs-plugin-babel": "^0.0.25",
    "systemjs-plugin-css": "^0.1.37",
    "systemjs-vue-browser": "^1.0.11",
    "vue": "^2.7.16"
  }
}
