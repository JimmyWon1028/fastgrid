{
  "name": "fabgrid",
  "version": "0.1.0",
  "private": true,
  "description": "Fabulous performance-first pure JavaScript data grid.",
  "type": "module",
  "main": "dist/fabui.js",
  "module": "dist/fabui.esm.js",
  "style": "dist/fabui.css",
  "scripts": {
    "build": "node build/build.cjs && node build/build-vue.cjs && node build/build-jquery.cjs && node build/build-editbox-jquery.cjs",
    "build:editbox-jquery": "node build/build-editbox-jquery.cjs",
    "build:vue": "node build/build-vue.cjs",
    "build:jquery": "node build/build-jquery.cjs && node build/build-editbox-jquery.cjs",
    "dev:vue": "python3 -m http.server 4174",
    "test": "node --test test/*.test.js",
    "test:jquery": "node --test test/jquery-wrapper.test.js",
    "smoke": "npm run build && node build/smoke.cjs",
    "serve": "python3 -m http.server 4173"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "systemjs": "^0.21.6",
    "systemjs-plugin-babel": "^0.0.25",
    "systemjs-plugin-css": "^0.1.37",
    "systemjs-vue-browser": "^1.0.11",
    "vue": "^2.7.16"
  }
}
